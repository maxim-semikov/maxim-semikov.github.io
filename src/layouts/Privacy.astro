---
import Terminal from './Terminal.astro';
import Prompt from '../components/Prompt.astro';

interface Props {
  /** App display name, shown in the eyebrow. */
  appName: string;
  /** Project slug → builds the breadcrumb and canonical URL. */
  slug: string;
  title: string;
  description: string;
}

const { appName, slug, title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const projectHref = `${base}projects/${slug}/`;
---

<Terminal
  title={title}
  description={description}
  mode="VIEW"
  path={`~/projects/${slug}/privacy`}
  canonical={`/projects/${slug}/privacy/`}
  crumbs={[
    { label: '~', href: base },
    { label: 'projects', href: `${base}#projects` },
    { label: slug, href: projectHref },
    { label: 'privacy' },
  ]}
>
  <article class="shell legal">
    <Prompt cmd="cat" arg="privacy.md" />
    <div class="eyebrow">{appName}</div>
    <slot />
    <p class="eof"># EOF<span class="cursor"></span></p>
  </article>
</Terminal>

<style>
  .legal {
    padding-top: 24px;
    padding-bottom: 40px;
  }
  .legal :global(p),
  .legal :global(ul),
  .legal :global(.meta),
  .legal :global(hr),
  .legal :global(header) {
    max-width: var(--maxw-text);
  }
  .eyebrow {
    color: var(--accent);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.72rem;
    margin-bottom: 6px;
  }
  .legal :global(h1) {
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin: 0 0 0.3em;
  }
  .legal :global(h2) {
    font-size: 1.15rem;
    margin: 1.8em 0 0.5em;
    color: var(--ink);
  }
  .legal :global(p),
  .legal :global(li) {
    color: var(--soft);
  }
  .legal :global(strong) {
    color: var(--ink);
  }
  .legal :global(ul) {
    padding-left: 1.3em;
  }
  .legal :global(li) {
    margin: 0.35em 0;
  }
  .legal :global(.meta),
  .legal :global(.muted) {
    color: var(--muted);
    font-size: 0.88rem;
  }
  .legal :global(.badge) {
    display: inline-block;
    margin-top: 8px;
    padding: 3px 10px;
    border: 1px solid var(--panel-line);
    border-radius: 999px;
    background: rgba(97, 175, 239, 0.06);
    color: var(--soft);
    font-size: 0.78rem;
  }
  .legal :global(hr) {
    border: none;
    border-top: 1px solid var(--panel-line);
    margin: 40px 0 8px;
  }
  .legal :global(.disclaimer) {
    color: var(--muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--panel-line);
    margin-top: 40px;
    padding-top: 20px;
  }
  .eof {
    margin-top: 32px;
    color: var(--faint);
  }
</style>
