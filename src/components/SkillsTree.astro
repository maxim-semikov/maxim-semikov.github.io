---
import { skills } from '../data/skills';

type Row =
  | { kind: 'root'; text: string }
  | { kind: 'dir'; branch: string; text: string }
  | { kind: 'leaf'; branch: string; text: string };

const rows: Row[] = [{ kind: 'root', text: 'skills/' }];
const cats = Object.entries(skills) as [string, readonly string[]][];

cats.forEach(([cat, items], ci) => {
  const lastCat = ci === cats.length - 1;
  rows.push({
    kind: 'dir',
    branch: lastCat ? '└── ' : '├── ',
    text: `${cat}/`,
  });
  const pad = lastCat ? '    ' : '│   ';
  items.forEach((item, ii) => {
    const lastItem = ii === items.length - 1;
    rows.push({ kind: 'leaf', branch: pad + (lastItem ? '└── ' : '├── '), text: item });
  });
});
---

<pre class="tree" aria-label="Skills">{rows.map((r) => (
  r.kind === 'root'
    ? <span class="line"><span class="root">{r.text}</span></span>
    : <span class="line"><span class="branch">{r.branch}</span><span class={r.kind}>{r.text}</span></span>
))}</pre>

<style>
  .tree {
    margin: 0;
    font-family: var(--mono);
    font-size: 0.92rem;
    line-height: 1.75;
    color: var(--soft);
    overflow-x: auto;
    padding: 18px 20px;
    background: var(--panel);
    border: 1px solid var(--panel-line);
    border-radius: var(--radius);
  }
  .line {
    display: block;
    white-space: pre;
  }
  .root {
    color: var(--accent-bright);
    font-weight: 700;
  }
  .branch {
    color: var(--faint);
  }
  .dir {
    color: var(--cyan);
  }
  .leaf {
    color: var(--ink);
  }
</style>
